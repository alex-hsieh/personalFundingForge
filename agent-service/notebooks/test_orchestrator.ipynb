    "results_2 = await test_full_pipeline(request_2)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Compare Pipeline Executions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare results\n",
    "print(\"PIPELINE COMPARISON\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "for i, results in enumerate([results_1, results_2], 1):\n",
    "    final = [r for r in results if r['done'] and r['agent'] == 'orchestrator'][0]['output']\n",
    "    \n",
    "    print(f\"\\nTest Case {i}:\")\n",
    "    print(f\"  Match Score: {final['matchScore']}%\")\n",
    "    print(f\"  Collaborators: {len(final['collaborators'])}\")\n",
    "    print(f\"  Compliance Items: {len(final['complianceChecklist'])}\")\n",
    "    print(f\"  Proposal Words: {len(final['proposalDraft'].split())}\")\n",
    "    \n",
    "    # Count agent steps\n",
    "    agent_steps = {}\n",
    "    for r in results:\n",
    "        agent = r['agent']\n",
    "        agent_steps[agent] = agent_steps.get(agent, 0) + 1\n",
    "    print(f\"  Agent Steps: {agent_steps}\")"
   ]
  }
