  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run complete pipeline\n",
    "async def test_full_pipeline(request):\n",
    "    start_time = datetime.now()\n",
    "    results = []\n",
    "    current_agent = None\n",
    "    \n",
    "    print(\"Starting pipeline execution...\\n\")\n",
    "    \n",
    "    async for message in orchestrate_pipeline(request):\n",
    "        results.append(message)\n",
    "        \n",
    "        # Track agent transitions\n",
    "        if message['agent'] != current_agent:\n",
    "            if current_agent:\n",
    "                print()\n",
    "            current_agent = message['agent']\n",
    "            print(f\"\\n[{message['agent'].upper()}]\")\n",
    "        \n",
    "        print(f\"  {message['step']}\")\n",
    "        \n",
    "        if message['done'] and message['agent'] == 'orchestrator':\n",
    "            end_time = datetime.now()\n",
    "            duration = (end_time - start_time).total_seconds()\n",
    "            \n",
    "            print(\"\\n\" + \"=\"*70)\n",
    "            print(\"PIPELINE COMPLETE\")\n",
    "            print(\"=\"*70)\n",
    "            print(f\"\\nExecution Time: {duration:.2f} seconds\")\n",
    "            \n",
    "            output = message['output']\n",
    "            print(f\"\\nMatch Score: {output['matchScore']}%\")\n",
    "            print(f\"Collaborators: {len(output['collaborators'])}\")\n",
    "            print(f\"Compliance Items: {len(output['complianceChecklist'])}\")\n",
    "            print(f\"Proposal Length: {len(output['proposalDraft'].split())} words\")\n",
    "    \n",
    "    return results\n",
    "\n",
    "results_1 = await test_full_pipeline(request_1)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Detailed Results Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract final output\n",
    "final_output = [r for r in results_1 if r['done'] and r['agent'] == 'orchestrator'][0]['output']\n",
    "\n",
    "print(\"FINAL OUTPUT ANALYSIS\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "print(\"\\n1. MATCH ANALYSIS\")\n",
    "print(f\"   Score: {final_output['matchScore']}%\")\n",
    "print(f\"   Justification: {final_output['matchJustification'][:100]}...\")\n",
    "\n",
    "print(\"\\n2. COLLABORATORS\")\n",
    "for i, collab in enumerate(final_output['collaborators'], 1):\n",
    "    print(f\"   {i}. {collab['name']} ({collab['department']})\")\n",
    "    print(f\"      Relevance: {collab.get('relevanceScore', 'N/A')}%\")\n",
    "\n",
    "print(\"\\n3. COMPLIANCE CHECKLIST\")\n",
    "for item in final_output['complianceChecklist']:\n",
    "    status_icon = {'green': '✓', 'yellow': '⚠', 'red': '✗'}.get(item['status'], '?')\n",
    "    print(f\"   [{status_icon}] {item['task']} ({item['category']})\")\n",
    "\n",
    "print(\"\\n4. PROPOSAL DRAFT\")\n",
    "print(f\"   Word Count: {len(final_output['proposalDraft'].split())}\")\n",
    "print(f\"   Preview: {final_output['proposalDraft'][:200]}...\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Test Case 2: Environmental Science Grant"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
