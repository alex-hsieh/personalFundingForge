   "source": [
    "# OrchestratorAgent Test Notebook\n",
    "\n",
    "This notebook tests the complete multi-agent pipeline orchestration.\n",
    "\n",
    "**Execution Order**: SourcingAgent → MatchmakingAgent → CollaboratorAgent → DraftingAgent"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "import asyncio\n",
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "sys.path.append(os.path.dirname(os.path.abspath('')))\n",
    "\n",
    "from agents.orchestrator import orchestrate_pipeline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Test Case 1: Complete Pipeline - AI Healthcare Grant"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Complete request payload\n",
    "request_1 = {\n",
    "    \"grantId\": \"NSF-AI-2024-001\",\n",
    "    \"grantName\": \"NSF AI for Healthcare Innovation\",\n",
    "    \"matchCriteria\": \"AI/ML applications in healthcare, interdisciplinary collaboration\",\n",
    "    \"eligibility\": \"Assistant or Associate Professor, STEM field, less than 7 years since PhD\",\n",
    "    \"userProfile\": {\n",
    "        \"role\": \"Assistant Professor\",\n",
    "        \"year\": \"2023\",\n",
    "        \"program\": \"Computer Science\"\n",
    "    },\n",
    "    \"facultyList\": [\n",
    "        {\"name\": \"Dr. Sarah Chen\", \"department\": \"Computer Science\", \"expertise\": \"Machine Learning, NLP\"},\n",
    "        {\"name\": \"Dr. Michael Rodriguez\", \"department\": \"Biomedical Engineering\", \"expertise\": \"Medical Imaging, AI\"},\n",
    "        {\"name\": \"Dr. Lisa Park\", \"department\": \"Public Health\", \"expertise\": \"Epidemiology, Health Informatics\"},\n",
    "        {\"name\": \"Dr. Emily Thompson\", \"department\": \"Statistics\", \"expertise\": \"Bayesian Methods, Data Science\"},\n",
    "        {\"name\": \"Dr. James Wilson\", \"department\": \"Computer Science\", \"expertise\": \"Computer Vision, Robotics\"}\n",
    "    ]\n",
    "}\n",
    "\n",
    "print(\"Test Case 1: AI Healthcare Grant Pipeline\")\n",
    "print(f\"Grant: {request_1['grantName']}\")\n",
    "print(f\"User: {request_1['userProfile']['role']} in {request_1['userProfile']['program']}\")\n",
    "print(f\"Faculty Pool: {len(request_1['facultyList'])} members\")\n",
    "print(\"\\n\" + \"=\"*70 + \"\\n\")"
   ]
  }
 ],
