    "        \"program\": \"Environmental Science\"\n",
    "    },\n",
    "    \"facultyList\": [\n",
    "        {\"name\": \"Dr. John Smith\", \"department\": \"Atmospheric Science\", \"expertise\": \"Climate Modeling\"},\n",
    "        {\"name\": \"Dr. Maria Garcia\", \"department\": \"Public Policy\", \"expertise\": \"Environmental Policy\"},\n",
    "        {\"name\": \"Dr. Robert Kumar\", \"department\": \"Statistics\", \"expertise\": \"Data Analysis\"}\n",
    "    ]\n",
    "}\n",
    "\n",
    "print(\"Test Case 2: Environmental Science Grant Pipeline\")\n",
